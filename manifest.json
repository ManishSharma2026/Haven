{
  "manifest_version": 3,
  "name": "Haven",
  "version": "1.0",
  "description": "Safer browsing, clearer signals",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "tabs", "scripting", "storage"],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:3000/*",
    "https://amqxelapdljxeujuduye.supabase.co/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}